# Zerion API Authentication
ZERION_API_KEY=zk_YOUR_API_KEY_HERE

# DarkBook Configuration
DARKBOOK_PROGRAM_ID=YOUR_PROGRAM_ID_HERE

# Keypair Management
ZERION_AGENT_KEYPAIR_PATH=/path/to/keypair.json

# RPC Configuration
RPC_URL=https://api.devnet.solana.com

# Risk Management
MAX_POSITION_SIZE=10000
MAX_DRAWDOWN=0.2
MAX_LEVERAGE=5

# Agent Polling
POLL_INTERVAL_SECONDS=60
