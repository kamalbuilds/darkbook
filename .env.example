# DarkBook environment template
# Copy to .env and fill in values that are unset.

# ─── Solana ───────────────────────────────────────────────────────────────────
ANCHOR_WALLET=
RPC_URL=https://api.devnet.solana.com
# Set after `anchor deploy` (initial value matches Anchor.toml's localnet declare_id)
PROGRAM_ID=9i4Gpnt8GgrwxqwXdEyjFBsfNChis8z9jmyAbMpFVLcS

# ─── MagicBlock Ephemeral Rollup ──────────────────────────────────────────────
ER_RPC=https://devnet-us.magicblock.app/
ER_WS=wss://devnet-us.magicblock.app/
ER_VALIDATOR=MAS1Dt9qreoRMQ14YQuhg8UTZMMzDdKhmkZMECCzk57

# ─── Pyth Lazer ───────────────────────────────────────────────────────────────
PYTH_LAZER_WS=wss://pyth-lazer.dourolabs.app/v1/stream
# Get from https://tally.so/r/nP2lG5 (Pyth Lazer access form)
PYTH_LAZER_TOKEN=

# Devnet SOL/USD feed id
SOL_USD_FEED_HEX=0xef0d8b6fda2ceba41da15d4095d1da392a0d2f8ed0c6c7bc0f4cfac8c280b56d

# ─── Services ─────────────────────────────────────────────────────────────────
SETTLER_PORT=8081
ER_BROADCASTER_PORT=8082
LIQUIDATION_WATCHER_PORT=8083
FUNDING_CRON_PORT=8084
FAUCET_PORT=8083

# Devnet USDC mint — set after running: bun run scripts/setup-test-usdc.ts
USDC_DEVNET_MINT=<set after running setup-test-usdc.ts>

# Faucet authority keypair path (generated by setup-test-usdc.ts, keep gitignored)
FAUCET_AUTHORITY_KEYPAIR=./.faucet-authority.json

# Settler keypair JSON (output of `solana-keygen new --no-bip39-passphrase --outfile settler.json`).
# Either path or inline JSON array.
SETTLER_SECRET_KEY=

# Market public key (set after running scripts/setup-market.ts)
MARKET_PUBKEY=

# Logging
LOG_LEVEL=info

# ─── Tracing ─────────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_SERVICE_NAME=darkbook

# ─── Dashboard (Next.js) ─────────────────────────────────────────────────────
# Mirrored from above for the browser bundle. NEVER put secrets in NEXT_PUBLIC_*.
NEXT_PUBLIC_PROGRAM_ID=9i4Gpnt8GgrwxqwXdEyjFBsfNChis8z9jmyAbMpFVLcS
NEXT_PUBLIC_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_ER_RPC=https://devnet-us.magicblock.app/
NEXT_PUBLIC_ER_WS=wss://devnet-us.magicblock.app/
NEXT_PUBLIC_PYTH_LAZER_WS=wss://pyth-lazer.dourolabs.app/v1/stream
NEXT_PUBLIC_SOL_USD_FEED=0xef0d8b6fda2ceba41da15d4095d1da392a0d2f8ed0c6c7bc0f4cfac8c280b56d
NEXT_PUBLIC_USDC_MINT=Gh9ZwEmdLJ8DscKNTkTqPbNwLNNBjuSzaG9Vp2KGtKJr
NEXT_PUBLIC_SETTLER_URL=http://localhost:8081
NEXT_PUBLIC_BROADCASTER_URL=http://localhost:8082
NEXT_PUBLIC_FAUCET_URL=http://localhost:8083
# Set to "true" on devnet to show the faucet button in the dashboard
NEXT_PUBLIC_IS_DEVNET=true

# ─── Jupiter Swap Integration ─────────────────────────────────
# Optional API key for higher rate limits (public tier works)
NEXT_PUBLIC_JUPITER_API_KEY=

# ─── Birdeye Chart Integration ────────────────────────────────
# Optional API key for historical OHLCV data (public tier works)
NEXT_PUBLIC_BIRDEYE_API_KEY=

# ─── Jito Bundle Settings ─────────────────────────────────────
# Jito Block Engine URL for atomic settlement (defaults to mainnet)
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf
# Jito tip amount in lamports (default 10000 = 0.00001 SOL)
JITO_TIP_LAMPORTS=10000
