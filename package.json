{
  "name": "darkbook-monorepo",
  "private": true,
  "license": "ISC",
  "workspaces": [
    "sdk",
    "dashboard",
    "services/*"
  ],
  "scripts": {
    "build:program": "anchor build",
    "build:sdk": "bun run -F @darkbook/sdk build",
    "build:dashboard": "bun run -F dashboard build",
    "build:services": "bun run -F '@darkbook/settler' build && bun run -F '@darkbook/er-broadcaster' build && bun run -F '@darkbook/funding-cron' build && bun run -F '@darkbook/liquidation-watcher' build",
    "build:all": "bun run build:program && bun run build:sdk && bun run build:services && bun run build:dashboard",
    "typecheck:sdk": "bun run -F @darkbook/sdk typecheck",
    "typecheck:services": "bun run -F '@darkbook/settler' typecheck && bun run -F '@darkbook/er-broadcaster' typecheck && bun run -F '@darkbook/funding-cron' typecheck && bun run -F '@darkbook/liquidation-watcher' typecheck",
    "test": "anchor test",
    "deploy:devnet": "bash scripts/deploy-devnet.sh",
    "demo": "bun run scripts/demo.ts",
    "demo:devnet": "bash scripts/demo-devnet.sh",
    "demo:local": "bash scripts/demo-local.sh",
    "demo:state": "bun run scripts/print-state.ts",
    "demo:airdrop": "bun run scripts/airdrop.ts",
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@darkbook/sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "0.7.0",
    "@solana/spl-token": "^0.4.13",
    "@solana/web3.js": "^1.98.0",
    "anchor-bankrun": "^0.5.0",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "ora": "^8.1.1",
    "solana-bankrun": "^0.4.0"
  },
  "devDependencies": {
    "@noble/hashes": "^1.7.0",
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.7.3"
  }
}
